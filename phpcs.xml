<?xml version="1.0"?>
<ruleset name="Chinh Toa Media">
    <description>WordPress Coding Standards cho theme Chính Tòa Media.</description>

    <!-- Quét theme; bỏ qua thư viện bên thứ ba và file build. -->
    <file>chinhtoa</file>
    <exclude-pattern>*/inc/tgma/*</exclude-pattern>
    <exclude-pattern>*/inc/vendor/*</exclude-pattern>
    <exclude-pattern>*/assets/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg value="ps"/>

    <!-- Cần cài WordPress Coding Standards: https://github.com/WordPress/WordPress-Coding-Standards -->
    <rule ref="WordPress">
        <!-- Theme chấp nhận tiền tố hàm ct_/gen_/home_/bb_ trong giai đoạn chuyển đổi. -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals"/>
    </rule>

    <config name="minimum_supported_wp_version" value="5.4"/>
    <config name="testVersion" value="7.4-"/>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array" value="chinhtoa"/>
        </properties>
    </rule>
</ruleset>
